# Copy the values you need into `.kamal/secrets`.
# Keep `.kamal/secrets` out of git.

KAMAL_REGISTRY_PASSWORD=replace-me-ghcr-token
RAILS_MASTER_KEY=$(cat config/master.key)
CREEM_API_KEY=replace-me-creem-api-key
CREEM_WEBHOOK_SECRET=replace-me-creem-webhook-secret
SUPPORT_API_KEY=replace-me-support-api-key
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace-me-primary-key
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace-me-deterministic-key
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace-me-key-derivation-salt
